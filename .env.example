# Backend GraphQL API URL
NEXT_PUBLIC_GRAPHQL_URI="https://api.golfguiders.net/graphql"

# Auth app URL (login/redirect – required for middleware and logout)
NEXT_PUBLIC_AUTH_URL="https://your-auth-domain.com"
NEXT_PUBLIC_AUTH_LOGOUT_URL="https://your-auth-domain.com/logout"
NEXT_PUBLIC_AUTH_DOMAIN="https://auth-dev.golfguiders.com"
NEXT_PUBLIC_APP_DOMAIN="https://app-dev.golfguiders.com"
NEXT_PUBLIC_STORE_DOMAIN="https://store-dev.golfguiders.com"

# GolfGuiders AI API
GOLFGUIDERS_GPT_URL="https://ai-golfguiders.vercel.app"
GOLFERGPT_X_API_KEY=

# Google Maps API Key
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Ably Realtime API Key
NEXT_PUBLIC_ABLY_API_KEY=

# Firebase (for push notifications)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# Firestore notification collection (read-only push notifications)
FIRESTORE_NOTIFICATION_BUCKET="dev_notification_activity"